# generate_bytes_header.cmake — emit a binary file as a ROM-resident C++ byte
# array header. A neutral, generic companion to generate_charset_header.cmake:
# identical output shape, but the assert wording does not assume the payload is a
# charset, so it reads correctly for map chunks and other raw byte assets.
#
# Required: -DINPUT=<binary> -DOUTPUT=<header.h>
# Optional: -DSYMBOL=<name>   (default kBytes)
#           -DNAMESPACE=<ns>  (default demo::assets)
#           -DEXPECT_BYTES=<n> (if set, asserts the exact byte count)

if(NOT DEFINED INPUT)
    message(FATAL_ERROR "INPUT is required")
endif()
if(NOT DEFINED OUTPUT)
    message(FATAL_ERROR "OUTPUT is required")
endif()
if(NOT DEFINED SYMBOL)
    set(SYMBOL kBytes)
endif()
if(NOT DEFINED NAMESPACE)
    set(NAMESPACE "demo::assets")
endif()

get_filename_component(INPUT_NAME "${INPUT}" NAME)
file(READ "${INPUT}" HEX_CONTENT HEX)
string(LENGTH "${HEX_CONTENT}" HEX_LENGTH)
math(EXPR BYTE_COUNT "${HEX_LENGTH} / 2")
math(EXPR EXPECTED_HEX_LENGTH "${BYTE_COUNT} * 2")
if(NOT HEX_LENGTH EQUAL EXPECTED_HEX_LENGTH)
    message(FATAL_ERROR "${INPUT} does not contain a whole number of bytes")
endif()
if(DEFINED EXPECT_BYTES AND NOT BYTE_COUNT EQUAL EXPECT_BYTES)
    message(FATAL_ERROR "${INPUT} is ${BYTE_COUNT} bytes; expected ${EXPECT_BYTES}")
endif()

set(CONTENT "#pragma once\n\n")
string(APPEND CONTENT "// Generated from ${INPUT_NAME} by cmake/generate_bytes_header.cmake.\n")
string(APPEND CONTENT "// Do not edit this file directly; update the source binary instead.\n")
string(APPEND CONTENT "namespace ${NAMESPACE} {\n\n")
string(APPEND CONTENT "inline constexpr unsigned char ${SYMBOL}[${BYTE_COUNT}] = {\n")

math(EXPR LAST_INDEX "${BYTE_COUNT} - 1")
foreach(INDEX RANGE 0 ${LAST_INDEX})
    math(EXPR OFFSET "${INDEX} * 2")
    string(SUBSTRING "${HEX_CONTENT}" ${OFFSET} 2 BYTE_HEX)
    string(TOLOWER "${BYTE_HEX}" BYTE_HEX)
    math(EXPR COLUMN "${INDEX} % 12")
    if(COLUMN EQUAL 0)
        string(APPEND CONTENT "  ")
    endif()
    string(APPEND CONTENT "0x${BYTE_HEX}")
    if(NOT INDEX EQUAL LAST_INDEX)
        string(APPEND CONTENT ",")
        math(EXPR NEXT_COLUMN "(${INDEX} + 1) % 12")
        if(NEXT_COLUMN EQUAL 0)
            string(APPEND CONTENT "\n")
        else()
            string(APPEND CONTENT " ")
        endif()
    else()
        string(APPEND CONTENT "\n")
    endif()
endforeach()

string(APPEND CONTENT "};\n\n")
string(APPEND CONTENT "static_assert(sizeof(${SYMBOL}) == ${BYTE_COUNT},\n")
string(APPEND CONTENT "              \"${INPUT_NAME} must stay ${BYTE_COUNT} bytes\");\n\n")
string(APPEND CONTENT "}  // namespace ${NAMESPACE}\n")

file(WRITE "${OUTPUT}" "${CONTENT}")
